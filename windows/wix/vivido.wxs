<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="Vivido Suite"
           Manufacturer="$(var.Publisher)"
           Version="$(var.VividoVersion)"
           UpgradeCode="87c21c74-dbd5-4584-89d5-46d9cd0c40a7"
           Scope="perUser"
           Language="1033"
           Codepage="65001"
           InstallerVersion="500">
    <SummaryInformation Description="Vivido terminal media suite for Windows 11 x64" />
    <MajorUpgrade AllowSameVersionUpgrades="no"
                  Schedule="afterInstallInitialize"
                  DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <Upgrade Id="87c21c74-dbd5-4584-89d5-46d9cd0c40a7">
      <UpgradeVersion Minimum="$(var.VividoVersion)"
                      IncludeMinimum="yes"
                      OnlyDetect="yes"
                      Property="VIVIDO_SAME_OR_NEWER_FOUND" />
    </Upgrade>
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="VividoIco" SourceFile="$(var.SourceRoot)\vivido.ico" />
    <Property Id="ARPPRODUCTICON" Value="VividoIco" />
    <Property Id="ARPURLINFOABOUT" Value="https://vivido.dev" />
    <Property Id="VIVIDOUSERPROFILE" Value="%USERPROFILE%" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.SourceRoot)\wix\license.rtf" />
    <ui:WixUI Id="WixUI_Minimal" />

    <Launch Condition="VersionNT64 AND WindowsBuild &gt;= 22000"
            Message="Vivido Suite requires 64-bit Windows 11 (build 22000 or newer)." />
    <Launch Condition="Installed OR NOT VIVIDO_SAME_OR_NEWER_FOUND"
            Message="The same or a newer version of Vivido Suite is already installed. Use Repair for the existing installation." />

    <Feature Id="ProductFeature" Title="Vivido Suite" Level="1">
      <ComponentGroupRef Id="SuiteFiles" />
      <ComponentRef Id="SetupHelperComponent" />
      <ComponentRef Id="UserPathComponent" />
      <ComponentRef Id="StartMenuComponent" />
    </Feature>

    <StandardDirectory Id="PerUserProgramFilesFolder">
      <Directory Id="INSTALLFOLDER" Name="Vivido">
        <Directory Id="LicensesFolder" Name="LICENSES" />
        <Directory Id="InstallerHelperFolder" Name="installer" />
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Vivido" />
    </StandardDirectory>

    <Component Id="SetupHelperComponent" Directory="InstallerHelperFolder" Guid="*">
      <File Id="SetupHelperFile"
            Source="$(var.StageDir)\installer\vivido-windows-setup.exe"
            Name="vivido-windows-setup.exe" />
      <RegistryValue Root="HKCU"
                     Key="Software\Vivido\Suite\Components"
                     Name="SetupHelper"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <Component Id="UserPathComponent" Directory="INSTALLFOLDER" Guid="*">
      <Environment Id="UserPath"
                   Name="PATH"
                   Value="[INSTALLFOLDER]"
                   Action="set"
                   Part="last"
                   Permanent="no"
                   System="no" />
      <RegistryValue Root="HKCU"
                     Key="Software\Vivido\Suite"
                     Name="PathInstalled"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <Component Id="StartMenuComponent" Directory="ApplicationProgramsFolder" Guid="*">
      <Shortcut Id="VividoPowerShellShortcut"
                Name="Vivido PowerShell"
                Description="Start Vivido with PowerShell 7"
                Target="[INSTALLFOLDER]vivido.exe"
                Arguments="-e pwsh.exe"
                WorkingDirectory="VIVIDOUSERPROFILE"
                Icon="VividoIco" />
      <Shortcut Id="VividoWslShortcut"
                Name="Vivido WSL"
                Description="Start Vivido with the default WSL distribution"
                Target="[INSTALLFOLDER]vivido.exe"
                Arguments="-e wsl.exe"
                WorkingDirectory="VIVIDOUSERPROFILE"
                Icon="VividoIco" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\Vivido\Suite"
                     Name="ShortcutsInstalled"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <CustomAction Id="InitializeUserConfig"
                  FileRef="SetupHelperFile"
                  ExeCommand="config-init"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="check" />
    <CustomAction Id="RefuseLiveVvmuxSessions"
                  FileRef="SetupHelperFile"
                  ExeCommand="vvmux-check"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="check" />
    <InstallExecuteSequence>
      <Custom Action="InitializeUserConfig"
              After="InstallFiles"
              Condition="NOT Installed" />
      <Custom Action="RefuseLiveVvmuxSessions"
              Before="RemoveFiles"
              Condition="REMOVE~=&quot;ALL&quot;" />
    </InstallExecuteSequence>
  </Package>
</Wix>
