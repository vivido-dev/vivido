<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
   <Package Name="Vivido" UpgradeCode="87c21c74-dbd5-4584-89d5-46d9cd0c40a7" Language="1033" Codepage="1252" Version="0.18.0-dev" Manufacturer="Vivido" InstallerVersion="200">
      <MajorUpgrade AllowSameVersionUpgrades="yes" DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
      <Icon Id="VividoIco" SourceFile=".\vivido\windows\vivido.ico" />
      <WixVariable Id="WixUILicenseRtf" Value=".\vivido\windows\wix\license.rtf" />
      <Property Id="ARPPRODUCTICON" Value="VividoIco" />
      <MediaTemplate EmbedCab="yes" />
      <ui:WixUI Id="WixUI_Minimal" />
      <Feature Id="ProductFeature" Title="ConsoleApp" Level="1">
         <ComponentRef Id="VividoExe" />
         <ComponentRef Id="VividoShortcut" />
         <ComponentRef Id="ModifyPathEnv" />
         <ComponentRef Id="ContextMenu" />
         <ComponentRef Id="ContextMenuFolder" />
      </Feature>
      <!-- Application binaries -->
      <DirectoryRef Id="VividoProgramFiles">
         <Component Id="VividoExe">
            <File Id="VividoExeFile" Source=".\target\release\vivido.exe" Name="vivido.exe" KeyPath="yes" />
         </Component>
      </DirectoryRef>
      <DirectoryRef Id="VividoProgramMenu">
         <!-- Application shortcut -->
         <Component Id="VividoShortcut" Guid="aa36e61a-23cd-4383-b744-2f78e912f0dc">
            <Shortcut Id="VividoShortcutFile" Name="Vivido" Description="A cross-platform, GPU-accelerated terminal emulator" Target="[VividoProgramFiles]vivido.exe" />
            <RemoveFolder Id="VividoProgramMenu" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\Microsoft\Vivido" Name="installed" Type="integer" Value="1" KeyPath="yes" />
         </Component>
      </DirectoryRef>
      <DirectoryRef Id="VividoProgramFiles">
         <!-- Add to PATH -->
         <Component Id="ModifyPathEnv" Guid="edf0b679-9eb6-46f7-a5d1-5160f30acb34" KeyPath="yes">
            <Environment Id="PathEnv" Value="[VividoProgramFiles]" Name="PATH" Permanent="no" Part="first" Action="set" System="yes" />
         </Component>
      </DirectoryRef>
      <StandardDirectory Id="ProgramFiles64Folder">
         <Directory Id="VividoProgramFiles" Name="Vivido" />
      </StandardDirectory>
      <StandardDirectory Id="ProgramMenuFolder">
         <Directory Id="VividoProgramMenu" Name="Vivido" />
      </StandardDirectory>
      <!-- Add context menu -->
      <Component Id="ContextMenu" Guid="449f9121-f7b9-41fe-82da-52349ea8ff91" Directory="TARGETDIR">
         <RegistryKey Root="HKCU" Key="Software\Classes\Directory\Background\shell\Open Vivido here\command">
            <RegistryValue Type="string" Value='[VividoProgramFiles]vivido.exe --working-directory "%v"' KeyPath="yes" />
         </RegistryKey>
         <RegistryKey Root="HKCU" Key="Software\Classes\Directory\Background\shell\Open Vivido here">
            <RegistryValue Type="string" Name="Icon" Value="[VividoProgramFiles]vivido.exe" />
         </RegistryKey>
      </Component>
      <Component Id="ContextMenuFolder" Guid="69483b38-a267-433f-9395-60827963347a" Directory="TARGETDIR">
         <RegistryKey Root="HKCU" Key="Software\Classes\Directory\shell\Open Vivido here\command">
            <RegistryValue Type="string" Value='[VividoProgramFiles]vivido.exe --working-directory "%v"' KeyPath="yes" />
         </RegistryKey>
         <RegistryKey Root="HKCU" Key="Software\Classes\Directory\shell\Open Vivido here">
            <RegistryValue Type="string" Name="Icon" Value="[VividoProgramFiles]vivido.exe" />
         </RegistryKey>
      </Component>
   </Package>
</Wix>
