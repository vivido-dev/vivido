  <name>Vivido</name>

  <project_license>Apache-2.0</project_license>

  <summary>A fast Vello/WebGPU terminal emulator</summary>
  <description>
    <p>
      Vivido is a modern terminal emulator that comes with sensible defaults,
      but allows for extensive configuration. By integrating with other
      applications, rather than reimplementing their functionality, it manages
      to provide a flexible set of features with high performance.
    </p>
    <ul>
      <li>Wayland native</li>
      <li>Wayland-only on Linux</li>
      <li>DE agnostic</li>
    </ul>
  </description>

  <categories>
    <category>TerminalEmulator</category>
  </categories>

